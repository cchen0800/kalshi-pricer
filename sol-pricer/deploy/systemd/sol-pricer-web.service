[Unit]
Description=sol-pricer SOL dashboard (read-only, port 5053)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/chris/kalshi-pricers/sol-pricer
ExecStart=/home/chris/kalshi-pricers/sol-pricer/.venv/bin/python dashboard.py --port 5053 --no-engine
Restart=on-failure
RestartSec=5
StandardOutput=append:/home/chris/kalshi-pricers/sol-pricer/logs/web.log
StandardError=append:/home/chris/kalshi-pricers/sol-pricer/logs/web.log
TimeoutStopSec=15

[Install]
WantedBy=default.target
